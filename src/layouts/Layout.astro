---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="DevOps Engineer Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-terminal-dark text-slate-300 font-sans antialiased selection:bg-terminal-green selection:text-terminal-dark">
		<slot />
	</body>
</html>

<style is:global>
	/* Custom Scrollbar for that terminal feel */
	::-webkit-scrollbar {
		width: 10px;
	}
	::-webkit-scrollbar-track {
		background: #0c0c0c;
	}
	::-webkit-scrollbar-thumb {
		background: #1e293b;
		border-radius: 2px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #4af626;
	}
</style>
