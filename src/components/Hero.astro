---
import { resume } from '../data/resume';
---

<section id="home" class="min-h-screen flex items-center justify-center pt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="space-y-6">
      <div class="inline-block px-3 py-1 border border-terminal-green/30 rounded-full bg-terminal-green/10">
        <span class="font-mono text-terminal-green text-sm">Running v2.0.25</span>
      </div>
      
      <h1 class="font-mono text-5xl md:text-7xl font-bold text-white tracking-tight">
        <span class="text-terminal-green">./</span>{resume.basics.name.replace(' ', '_')}
      </h1>
      
      <h2 class="text-2xl md:text-4xl text-slate-400 font-mono">
        &gt; {resume.basics.label}
      </h2>
      
      <p class="max-w-2xl text-lg text-slate-400 leading-relaxed border-l-2 border-terminal-slate pl-6">
        {resume.basics.summary}
      </p>

      <div class="flex flex-wrap gap-4 pt-4">
        <a 
          href="#contact"
          class="px-6 py-3 bg-terminal-green text-terminal-dark font-mono font-bold rounded hover:bg-green-400 transition-colors"
        >
          ./contact_me.sh
        </a>
        <a 
          href="#projects"
          class="px-6 py-3 border border-terminal-slate text-slate-300 font-mono rounded hover:border-terminal-green hover:text-terminal-green transition-colors"
        >
          cd ./projects
        </a>
      </div>

      <div class="pt-12 grid grid-cols-2 md:grid-cols-4 gap-4 text-sm font-mono text-slate-500">
        <div>
          <span class="block text-slate-600 mb-1">Location</span>
          {resume.basics.location}
        </div>
        <div>
          <span class="block text-slate-600 mb-1">Email</span>
          {resume.basics.email}
        </div>
        <div>
          <span class="block text-slate-600 mb-1">Phone</span>
          {resume.basics.phone}
        </div>
        <div>
          <span class="block text-slate-600 mb-1">Handle</span>
          @{resume.basics.handle}
        </div>
      </div>
    </div>
  </div>
</section>
