---
import { resume } from '../data/resume';
---

<section id="projects" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-mono text-3xl text-white mb-12 flex items-center">
      <span class="text-terminal-green mr-4">03.</span> 
      ~/projects
      <span class="ml-4 h-px bg-terminal-slate flex-grow"></span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {resume.projects.map((project) => (
        <a 
          href={`/projects/${project.name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '')}/`}
          class="block bg-terminal-slate/20 border border-terminal-slate/50 p-6 rounded hover:border-terminal-green/50 transition-all duration-300 hover:-translate-y-1 group"
        >
          <div class="flex justify-between items-start mb-4">
            <div class="text-terminal-green">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
            </div>
            <div class="flex space-x-4">
              <span class="text-xs font-mono text-slate-500 group-hover:text-terminal-green transition-colors">
                ./details
              </span>
            </div>
          </div>

          <h3 class="text-xl font-bold text-white mb-2 group-hover:text-terminal-green transition-colors">
            {project.name}
          </h3>
        </a>
      ))}
    </div>
  </div>
</section>
