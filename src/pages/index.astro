---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import OpenSource from '../components/OpenSource.astro';
import Skills from '../components/Skills.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CLI from '../components/CLI.astro';
import Certifications from '../components/Certifications.astro';
import Blog from '../components/Blog.astro';
import Footer from '../components/Footer.astro';
import { resume } from '../data/resume';

const siteUrl = "https://dev-joshi.pages.dev";

// Person Schema — enables Knowledge Panel
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Dev Joshi",
	"jobTitle": "DevOps Engineer",
	"worksFor": {
		"@type": "Organization",
		"name": "Inexture Solutions"
	},
	"url": "https://dev-joshi.pages.dev/",
	"image": `${siteUrl}/images/hero-devops.png`,
	"email": "https://calendly.com/joshid647/30min",
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Ahmedabad",
		"addressRegion": "Gujarat",
		"addressCountry": "IN"
	},
	"sameAs": [
		"https://linkedin.com/in/dev-joshi-b82a04150",
		"https://github.com/dev-joshi-ops/"
	],
	"knowsAbout": [
		"DevOps",
		"Kubernetes",
		"AWS",
		"CI/CD",
		"Cloud Infrastructure"
	],
	"description": resume.basics.summary
};

// FAQPage Schema — enables FAQ rich results
const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "Are you available for full-time roles or just consulting?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "I'm open to freelance contracts or full-time roles. I want to build resilient cloud architectures and solve complex Kubernetes scaling problems, not sit in endless sprint planning meetings."
			}
		},
		{
			"@type": "Question",
			"name": "What is your primary tech stack?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "AWS/Azure, Kubernetes, Terraform, Docker, and CI/CD via GitHub Actions or Jenkins. I also write automation scripts in Python and Go to eliminate manual toil."
			}
		},
		{
			"@type": "Question",
			"name": "Do you offer infrastructure audits?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. I hunt down performance bottlenecks, patch security holes, and slash unnecessary cloud bills. I build and optimize infrastructure as if I had to pay for it myself."
			}
		},
		{
			"@type": "Question",
			"name": "Can you work with legacy on-prem systems?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Absolutely. I've ripped out plenty of brittle legacy setups and safely migrated on-prem infrastructure to the cloud without dropping production traffic."
			}
		}
	]
};

// WebSite Schema — enables sitelinks
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Dev Joshi | DevOps Portfolio",
	"url": siteUrl,
	"description": "DevOps Engineer portfolio. Battle-tested cloud infrastructure, Kubernetes orchestration, CI/CD pipelines, and robust automation.",
	"author": { "@type": "Person", "name": "Dev Joshi" }
};
---

<Layout
	title={`${resume.basics.name} | DevOps Engineer | Cloud, Kubernetes & CI/CD`}
	description="Dev Joshi | DevOps Engineer based in Ahmedabad, Gujarat, India, building scalable cloud infrastructure on AWS, GCP & Azure. Kubernetes, Terraform, CI/CD & SOC 2 expert."
	jsonLd={[personSchema, faqSchema, websiteSchema]}
>
	<Navbar />
	<main>
		<Hero />
		<Skills />
		<Experience />
		<Certifications />
		<Projects />
		<OpenSource />
        <Blog />
        <Testimonials />
        <FAQ />
        <CLI />
	</main>
    <Footer />
</Layout>
